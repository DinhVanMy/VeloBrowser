      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@%2$@"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "A label displaying the number of ads blocked by the ad blocker. The argument is the count of blocked ads.",
      "isCommentAutoGenerated" : true
    },
    "%lld ads blocked" : {
      "comment" : "A badge indicating that a certain number of ads have been blocked. The argument is the number of ads that have been blocked.",
      "isCommentAutoGenerated" : true
    },
    "%lld cookies" : {
      "comment" : "A label showing the number of cookies stored in a given domain. The argument is the count of cookies in the specified domain.",
      "isCommentAutoGenerated" : true
    },
