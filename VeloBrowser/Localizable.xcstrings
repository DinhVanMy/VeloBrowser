      "comment" : "A label that combines the title of a bookmark with its URL host. The first argument is the title of the bookmark. The second argument is the host of the bookmark's URL.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@, %2$@"
